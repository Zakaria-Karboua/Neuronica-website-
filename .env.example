DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Leave empty for local dev (uses SQLite). Set this in production to your
# Neon Postgres connection string, e.g. postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
DATABASE_URL=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# AI tutor (free tier) — get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
